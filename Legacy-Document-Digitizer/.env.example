# .env.example
# Copy to .env and fill in values.
# Never commit .env to source control.
#
# Load with: docker run --env-file .env ...
#        or: export $(cat .env | xargs) && python main.py ...

# ---- Required ----
GITHUB_TOKEN=your_github_pat_here

# ---- Model (optional) ----
MODEL_NAME=gpt-4o-mini          # or gpt-4o
GITHUB_ENDPOINT=https://models.inference.ai.azure.com
API_DELAY_SECONDS=4
MAX_RETRIES=3
TIMEOUT_SECONDS=120

# ---- Ingestor (optional) ----
OUTPUT_DIR=/tmp/ingestor
TARGET_DPI=300
NATIVE_TEXT_MIN_CHARS=10

# ---- Mapper (optional) ----
CONFIDENCE_THRESHOLD=0.72
MATH_TOLERANCE=0.05

# ---- SAP defaults (optional) ----
SAP_COMPANY_CODE=1000
SAP_DOC_TYPE=RE
SAP_CURRENCY=INR

# ---- Logging (optional) ----
LOG_LEVEL=INFO
